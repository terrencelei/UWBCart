<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>CartView</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>CartView uses the local network to discover nearby devices for UWB ranging.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_uwb-cart._tcp</string>
	</array>
	<key>NSNearbyInteractionUsageDescription</key>
	<string>CartView uses Nearby Interaction to track the position of nearby devices.</string>
</dict>
</plist>
